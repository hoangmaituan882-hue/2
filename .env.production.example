# Frontend build-time API URL
VITE_CONTENT_API_URL="https://api.example.com"

# Runtime
NODE_ENV="production"
CONTENT_API_PORT="8787"
CONTENT_API_TRUST_PROXY="1"
CONTENT_API_REQUIRE_HTTPS="true"
CONTENT_API_SECURITY_HEADERS="true"
CONTENT_API_JSON_LIMIT="1mb"

# Strict CORS allowlist. Include every public frontend origin.
CONTENT_API_CORS_ORIGINS="https://example.com,https://www.example.com"
APP_URL="https://example.com"

# PostgreSQL
DATABASE_URL="postgres://user:password@db-host:5432/anysoul"

# Owner identities. Replace the development default before production.
OWNER_ACCOUNT_IDS="owner@example.com"

# Rate limits
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS="900000"
AUTH_LOGIN_RATE_LIMIT_MAX="10"
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS="3600000"
AUTH_REGISTER_RATE_LIMIT_MAX="5"
ADMIN_WRITE_RATE_LIMIT_WINDOW_MS="600000"
ADMIN_WRITE_RATE_LIMIT_MAX="120"

# Uploads
MEDIA_UPLOAD_MAX_BYTES="5242880"
OBJECT_STORAGE_DRIVER="r2"
OBJECT_STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
OBJECT_STORAGE_BUCKET="anysoul-media"
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
OBJECT_STORAGE_PUBLIC_BASE_URL="https://media.example.com"
OBJECT_STORAGE_PREFIX="uploads"
OBJECT_STORAGE_FORCE_PATH_STYLE="true"

# Optional providers
TMDB_API_KEY=""
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
