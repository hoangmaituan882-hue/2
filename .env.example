# Frontend
VITE_CONTENT_API_URL="http://localhost:8787"

# Content API
NODE_ENV="development"
CONTENT_API_PORT="8787"
CONTENT_API_TRUST_PROXY="1"
CONTENT_API_REQUIRE_HTTPS="false"
CONTENT_API_SECURITY_HEADERS="true"
CONTENT_API_JSON_LIMIT="1mb"
CONTENT_API_CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Public app URL used as an additional CORS origin in hosted deployments.
APP_URL="https://example.com"

# PostgreSQL enables real auth, user management, content publishing, gallery,
# screenings, submissions, posts and media metadata storage.
# Use a local PostgreSQL instance or a managed PostgreSQL service.
DATABASE_URL="postgres://user:password@localhost:5432/anysoul"

# Exact id/email/name values that should be treated as site owners.
OWNER_ACCOUNT_IDS="2546399970"

# App-level rate limits.
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS="900000"
AUTH_LOGIN_RATE_LIMIT_MAX="10"
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS="3600000"
AUTH_REGISTER_RATE_LIMIT_MAX="5"
ADMIN_WRITE_RATE_LIMIT_WINDOW_MS="600000"
ADMIN_WRITE_RATE_LIMIT_MAX="120"

# Optional metadata providers for the screenings source library.
TMDB_API_KEY=""

# Optional AI completion provider for source metadata cleanup.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# Image uploads.
# local: saves to server/data/uploads and serves from http://localhost:8787/uploads/...
# s3/r2: uploads with S3-compatible Signature V4 to Cloudflare R2, AWS S3,
# Alibaba OSS S3-compatible endpoints, Tencent COS S3-compatible endpoints, etc.
MEDIA_UPLOAD_MAX_BYTES="5242880"
OBJECT_STORAGE_DRIVER="local"
OBJECT_STORAGE_ENDPOINT=""
OBJECT_STORAGE_BUCKET=""
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
OBJECT_STORAGE_PUBLIC_BASE_URL=""
OBJECT_STORAGE_PREFIX="uploads"
OBJECT_STORAGE_FORCE_PATH_STYLE="true"
